# TestFlow base URLs (mobile emulators cannot reach localhost the same way as desktop)
API_BASE_URL=http://localhost:5050
ANDROID_BASE_URL=http://10.0.2.2:5050
IOS_BASE_URL=http://127.0.0.1:5050
BASE_URL=http://localhost:5050

# Demo credentials
DEMO_EMAIL=demo@automation.io
DEMO_PASSWORD=Demo123!

# Platform: android | ios
PLATFORM=android

# Device capabilities
ANDROID_DEVICE=Android Emulator
ANDROID_VERSION=14.0
IOS_DEVICE=iPhone 15
IOS_VERSION=17.0

# Cloud (optional — BrowserStack / Sauce Labs)
# BROWSERSTACK_USERNAME=
# BROWSERSTACK_ACCESS_KEY=
# SAUCE_USERNAME=
# SAUCE_ACCESS_KEY=
