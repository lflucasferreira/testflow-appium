{
  "name": "testflow-appium",
  "version": "1.0.0",
  "private": true,
  "description": "Appium mobile web automation for TestFlow — mirror of Cypress, Playwright and PyTest suites",
  "scripts": {
    "slides": "npx serve . -p 3336",
    "slides:open": "npx serve . -p 3336 & sleep 1 && open http://localhost:3336/docs/",
    "slides:pdf": "node scripts/export-slides-pdf.mjs",
    "appium:doctor": "npx appium driver doctor uiautomator2 && npx appium driver doctor xcuitest",
    "appium:drivers": "bash scripts/ensure-appium-drivers.sh",
    "test": "wdio run wdio.conf.ts",
    "test:android": "PLATFORM=android wdio run wdio.conf.ts",
    "test:ios": "PLATFORM=ios wdio run wdio.ios.conf.ts",
    "test:both": "npm run test:android && npm run test:ios",
    "test:api": "mocha --config .mocharc.api.json",
    "test:smoke": "wdio run wdio.conf.ts --spec tests/smoke/**/*.spec.ts",
    "test:auth": "wdio run wdio.conf.ts --spec tests/auth/**/*.spec.ts",
    "test:dashboard": "wdio run wdio.conf.ts --spec tests/dashboard/**/*.spec.ts",
    "test:team": "wdio run wdio.conf.ts --spec tests/team/**/*.spec.ts",
    "test:settings": "wdio run wdio.conf.ts --spec tests/settings/**/*.spec.ts",
    "test:components": "wdio run wdio.conf.ts --spec tests/components/**/*.spec.ts",
    "test:wizard": "wdio run wdio.conf.ts --spec tests/wizard/**/*.spec.ts",
    "test:activity": "wdio run wdio.conf.ts --spec tests/activity/**/*.spec.ts",
    "test:advanced": "wdio run wdio.conf.ts --spec tests/advanced/**/*.spec.ts",
    "test:states": "wdio run wdio.conf.ts --spec tests/states/**/*.spec.ts",
    "test:layout": "wdio run wdio.conf.ts --spec tests/layout/**/*.spec.ts",
    "test:visual": "wdio run wdio.conf.ts --spec tests/visual/**/*.spec.ts",
    "test:gestures": "wdio run wdio.conf.ts --spec tests/gestures/**/*.spec.ts",
    "test:device": "wdio run wdio.conf.ts --spec tests/device/**/*.spec.ts",
    "test:contexts": "wdio run wdio.conf.ts --spec tests/contexts/**/*.spec.ts",
    "test:locators": "wdio run wdio.conf.ts --spec tests/locators/**/*.spec.ts",
    "test:grep:smoke": "wdio run wdio.conf.ts --mochaOpts.grep @smoke",
    "test:grep:regression": "wdio run wdio.conf.ts --mochaOpts.grep @regression",
    "test:grep:appium": "wdio run wdio.conf.ts --mochaOpts.grep @appium",
    "test:ci:android": "bash scripts/ci-android-suite.sh",
    "test:ci:android:smoke": "bash scripts/ci-android-smoke.sh",
    "check:testflow": "bash scripts/check-testflow.sh",
    "allure:generate": "bash scripts/generate-allure-report.sh",
    "allure:open": "npx allure open allure-report",
    "allure:serve": "npm run allure:generate && npm run allure:open",
    "allure:clean": "rm -rf allure-results allure-report",
    "report": "npm run allure:serve",
    "pages:prepare-allure": "bash scripts/prepare-allure-for-pages.sh",
    "pages:build": "bash scripts/build-pages-site.sh"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "@wdio/allure-reporter": "^9.28.0",
    "@wdio/appium-service": "^9.12.0",
    "@wdio/cli": "^9.12.0",
    "@wdio/globals": "^9.12.0",
    "@wdio/local-runner": "^9.12.0",
    "@wdio/mocha-framework": "^9.12.0",
    "@wdio/spec-reporter": "^9.12.0",
    "allure": "^3.11.0",
    "allure-mocha": "^3.10.0",
    "appium": "^2.18.0",
    "appium-uiautomator2-driver": "^4.2.7",
    "appium-xcuitest-driver": "^9.2.4",
    "axios": "^1.9.0",
    "decktape": "^3.16.1",
    "dotenv": "^16.5.0",
    "expect-webdriverio": "^5.1.1",
    "highlight.js": "^11.11.1",
    "mocha": "^11.7.6",
    "reveal.js": "^5.1.0",
    "serve": "^14.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
